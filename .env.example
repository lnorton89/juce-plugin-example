# LumaScope Activation Infrastructure — Required Environment Variables
# Copy this file to .env and fill in your actual values.
# See infra/manifest.yaml for the authoritative variable definitions.
# See docs/deployment.md and docs/cloud-infrastructure.md for setup guides.
#
# These are used by infra/bootstrap.ps1 to inject secrets into Wrangler/Cloudflare.
# NEVER commit actual secret values to Git.

# Lemon Squeezy
LEMON_WEBHOOK_SECRET=                # HMAC-SHA256 secret for webhook verification
LEMON_STORE_ID=                      # Store identifier from Lemon Squeezy
LEMON_PRODUCT_ID=                    # Product identifier from Lemon Squeezy
LEMON_VARIANT_ID=                    # Variant identifier from Lemon Squeezy

# Ed25519 Signing (Cloudflare Worker)
SIGNING_PRIVATE_KEY=                 # Private key for signing entitlement tokens
SIGNING_KEY_ID=                      # Identifier for the active signing key
SIGNING_PUBLIC_KEYS=                 # JSON public key ring for verification

# Environment
ENVIRONMENT=local                    # local, preview, or production

{
  "name": "lumascope-activation",
  "version": "0.1.0",
  "private": true,
  "description": "LumaScope activation Worker — Cloudflare Edge Worker for license activation, validation, and Lemon Squeezy webhook ingestion",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply --local",
    "migrate:remote": "wrangler d1 migrations apply",
    "types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.15",
    "@cloudflare/workers-types": "4.20260623.1",
    "typescript": "5.8.3",
    "vitest": "4.1.9",
    "wrangler": "4.100.0"
  }
}
